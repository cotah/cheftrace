# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (Railway provides DATABASE_URL automatically in production)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cheftrace

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
# Service role key — required for signed Storage URLs (Phase 2 invoice uploads).
# NEVER ship this to the frontend. Get it from Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard
# Bucket must exist in Supabase Storage (private). Defaults to "invoices".
INVOICES_BUCKET=invoices

# Gemini OCR (Phase 2 Sprint 6+) — get a free key at https://aistudio.google.com/
# When unset, the /invoices/{id}/process endpoint returns 503.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# rapidfuzz score (0-100) below which an OCR line item is left unmatched
OCR_MATCH_THRESHOLD=70

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000"]
